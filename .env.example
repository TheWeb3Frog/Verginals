# Verginals server config template. Copy to a file your process manager loads (e.g. /etc/verginals/verginals.env
# referenced by the systemd unit) and fill in the blanks. NEVER commit the filled-in file: it points at
# secrets. This template contains NO secrets and is safe to keep in git.

# --- network ---------------------------------------------------------------------------------
VERGINALS_NETWORK=mainnet          # mainnet | testnet (pins RPC + addresses + accepted quotes)

# --- HTTP binding ----------------------------------------------------------------------------
PORT=3400
VERGINALS_HOST=127.0.0.1           # keep loopback: reachable ONLY through the reverse proxy (HTTPS).
                                   # Do NOT set 0.0.0.0 in production (would bypass HTTPS + rate limiting).
VERGINALS_TRUST_PROXY=1            # trust X-Forwarded-For ONLY when behind a proxy you control (nginx/Caddy)

# --- Verge node RPC --------------------------------------------------------------------------
VERGINALS_RPC_HOST=127.0.0.1
VERGINALS_RPC_PORT=20103           # mainnet default 20103; testnet 20102
VERGINALS_RPC_USER=                # from your VERGE.conf (rpcuser)
VERGINALS_RPC_PASS=                # from your VERGE.conf (rpcpassword)  <-- secret
# VERGINALS_RPC_CONF=/path/to/VERGE.conf   # alternative: read user/pass from the conf file

# --- persistent state (jobs hold throwaway keys; keep OFF version control, on real disk) ------
VERGINALS_DATA_DIR=/var/lib/verginals/data

# --- collection (Alpha Verginals) ------------------------------------------------------------
VERGINALS_COLLECTION_DIR=/path/to/verginals   # dir with designs.json + images + collection_manifest.json

# --- collection root / parent-child membership (spec section 10) ------------------------------
# Leave BOTH blank until the root manifest is inscribed, then set them and restart:
#   1. create a DEDICATED key (holds ONLY the parent carrier, never your treasury):
#        verge-cli getnewaddress ; verge-cli dumpprivkey <that address>
#   2. write the WIF to  $VERGINALS_DATA_DIR/mint/parent.wif  with chmod 600  (preferred over the env var
#      below, which can leak into logs / the process list)
#   3. start the server once; it logs the carrier address to inscribe the manifest TO
#   4. inscribe collection_manifest.json paying its carrier to that address
#   5. set VERGINALS_PARENT_ID to <rootTxid>i0 and restart -> parenting ENABLED
VERGINALS_PARENT_ID=               # <rootTxid>i0 once the root exists (blank = genesis mints, no tag 3)
# VERGINALS_PARENT_WIF=            # secret; prefer the parent.wif FILE instead of this env var

# --- optional operator service fee -----------------------------------------------------------
VERGINALS_SERVICE_FEE_XVG=0        # 0 disables; capped at 5. Requires a valid fee address below.
VERGINALS_FEE_ADDRESS=             # your address that collects the service fee (must match network)

# --- indexing --------------------------------------------------------------------------------
# VERGINALS_INDEX_FROM=9290000     # first block to index (mainnet default 9290000, testnet 125800)

# --- tuning (safe defaults; override only if needed) -----------------------------------------
# VERGINALS_MINT_PER_INPUT_XVG=1   # deposit sizing per commit input
# VERGINALS_CACHE_MS=10000         # inscription list cache TTL
# VERGINALS_QUOTE_WINDOW_MS=60000  # rate-limit window
# VERGINALS_QUOTE_MAX=10           # max quotes/mints per window per client
# VERGINALS_MINT_RESERVE_TTL_MS=1800000    # how long an unpaid reservation is held (30 min)
# VERGINALS_SHOW_JOBS=0            # 1 = surface operator job files in the public list (leave 0 publicly)

# --- launch campaign: first N mints funded by the operator (OFF by default) ------------------
# When enabled AND a promo key is present, an eligible mint has its deposit funded from the promo
# wallet, so the minter pays nothing. The promo wallet is a hot wallet: keep only ~N mints of XVG
# in it. Fund the address the server prints at boot AFTER first start (it is imported watch-only
# with no rescan); if you funded it beforehand, run once with VERGINALS_PROMO_RESCAN=1.
# VERGINALS_PROMO_ENABLED=0        # 1 = campaign live. Flip back to 0 anytime to pause instantly.
# VERGINALS_PROMO_LIMIT=333        # total free mints
# VERGINALS_PROMO_MAX_PER_ADDR=1   # free mints allowed per receiving address
# VERGINALS_PROMO_MAX_PER_IP=2     # free mints allowed per client IP
# VERGINALS_PROMO_RESCAN=0         # 1 = rescan history on boot (only if the wallet was pre-funded)
# VERGINALS_PROMO_WIF=             # secret; prefer the data/promo.wif FILE instead of this env var
